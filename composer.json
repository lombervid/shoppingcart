{
    "name": "lombervid/shoppingcart",
    "type": "library",
    "description": "A simple shopping cart class for PHP",
    "keywords": [
        "shopping cart"
    ],
    "homepage": "https://github.com/lombervid/shoppingcart",
    "license": "MIT",
    "authors": [
        {
            "name": "David Lombera",
            "email": "david.lomberlan@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "rector/rector": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "Lombervid\\ShoppingCart\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lombervid\\ShoppingCart\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test:unit": "./vendor/bin/phpunit",
        "test:types": "./vendor/bin/phpstan",
        "test:refactor": "./vendor/bin/rector --dry-run",
        "test": [
            "@test:refactor",
            "@test:types",
            "@test:unit"
        ]
    }
}
